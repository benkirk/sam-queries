# SAM API Configuration
# STATUS_API_KEY is an API key, NOT a user login password.
# Generate a new key pair with:
#   python scripts/gen_api_key.py --username collector
# The printed key goes here; the printed hash goes in API_KEYS in src/webapp/config.py.
STATUS_API_URL=http://localhost:5050
STATUS_API_USER=collector
STATUS_API_KEY=YOUR_GENERATED_API_KEY_HERE

# Optional: Override log locations
# DERECHO_LOG_FILE=/var/log/derecho_collector.log
# CASPER_LOG_FILE=/var/log/casper_collector.log

# Optional: Collection timeout (seconds)
# PBS_COMMAND_TIMEOUT=30
# SSH_TIMEOUT=10
# API_TIMEOUT=30
