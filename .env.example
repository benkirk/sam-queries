#-------------------------------------------------
# local container instance
#   "local SAM" is used especially for testing and
#   should always have read/write access
LOCAL_SAM_DB_USERNAME=root
LOCAL_SAM_DB_SERVER=127.0.0.1
LOCAL_SAM_DB_PASSWORD=root

#-------------------------------------------------
# Production SAM instance (read-only)
#   Used for accessing production data
#   Contact CISL staff for credentials
PROD_SAM_DB_USERNAME=your_prod_username
PROD_SAM_DB_SERVER=sam-sql.ucar.edu
PROD_SAM_DB_PASSWORD='your_prod_password'

#-------------------------------------------------
# Staging SAM instance (AWS RDS, requires UCAR VPN)
#   Get credentials: ./scripts/infra/db-creds-staging.sh
#   Switch with: ./scripts/setup/switch_to_staging_db.sh
# STAGING_SAM_DB_USERNAME=<from db-creds-staging.sh>
# STAGING_SAM_DB_SERVER=<from db-creds-staging.sh>
# STAGING_SAM_DB_PASSWORD=<from db-creds-staging.sh>

#-------------------------------------------------
# "proper SAM" is the SAM instance used to feed our dashboards etc...
#
# Pick ONE block below by uncommenting. Leaving ALL of them commented
# is the default state for `install.sh`-generated `.env`. In that
# state, `compose.yaml`'s in-stack defaults route the docker stack
# to the bundled `mysql` service (host `mysql`, root/root). Any
# out-of-stack tools (sam-search from a conda env, alembic, ...)
# won't have SAM_DB_SERVER set until you uncomment one block here.
#
# IMPORTANT: whatever you uncomment also flows into the in-stack
# containers via compose `env_file:` (intentional pass-through).
# So uncommenting LOCAL points the in-stack webapp at 127.0.0.1
# (loopback inside the container, broken — use only if you are
# running sam-search out-of-stack and accept that webdev/webapp
# won't work). Uncommenting PROD points BOTH out-of-stack and
# in-stack at sam-sql.ucar.edu (useful for prod-data testing).

# Uncomment to use LOCAL (host loopback to docker mysql via 3306):
#SAM_DB_USERNAME=${LOCAL_SAM_DB_USERNAME}
#SAM_DB_SERVER=${LOCAL_SAM_DB_SERVER}
#SAM_DB_PASSWORD=${LOCAL_SAM_DB_PASSWORD}
#SAM_DB_REQUIRE_SSL=false

# Uncomment to use STAGING:
#SAM_DB_USERNAME=${STAGING_SAM_DB_USERNAME}
#SAM_DB_SERVER=${STAGING_SAM_DB_SERVER}
#SAM_DB_PASSWORD=${STAGING_SAM_DB_PASSWORD}
#SAM_DB_REQUIRE_SSL=false

# Uncomment to use PRODUCTION:
#SAM_DB_USERNAME=${PROD_SAM_DB_USERNAME}
#SAM_DB_SERVER=${PROD_SAM_DB_SERVER}
#SAM_DB_PASSWORD=${PROD_SAM_DB_PASSWORD}
#SAM_DB_REQUIRE_SSL=true

#-------------------------------------------------
# system_status database - used to populate the System Status
# Dashboard. STATUS_DB_DRIVER: "mysql" (default), "postgresql",
# or "postgres". Same pass-through rule as above — leaving the
# active lines commented lets compose.yaml route in-stack
# containers to the bundled `mysql` service.
STATUS_DB_DRIVER=mysql
# Uncomment for OUT-OF-STACK conda use against the docker mysql:
#STATUS_DB_USERNAME=root
#STATUS_DB_PASSWORD=root
#STATUS_DB_SERVER=127.0.0.1

#-------------------------------------------------
# Where our data collectors post their results
# STATUS_API_KEY is an API key (not a login password).  Generate a new pair with:
#   python scripts/gen_api_key.py --username collector
# The script prints two lines:
#   Collector .env  →  STATUS_API_KEY=<key>       ← goes here
#   Webapp env var  →  API_KEYS_COLLECTOR=<hash>  ← goes in compose.yaml / Helm values / SSM
STATUS_API_URL="http://localhost:5050"
STATUS_API_USER="collector"
STATUS_API_KEY="YOUR_GENERATED_API_KEY_HERE"
# API_KEYS_COLLECTOR="$2b$12$your_hash_here"      # webapp server-side hash (local dev)

#-------------------------------------------------
# JupyterHub Live Statistics API
# Used for real-time JupyterHub stats endpoints
JUPYTERHUB_API_URL=https://jupyterhub.hpc.ucar.edu
JUPYTERHUB_INSTANCE=stable
JUPYTERHUB_API_TOKEN=
JUPYTERHUB_CACHE_TTL=300

#-------------------------------------------------
# Email Configuration
MAIL_SERVER=ndir.ucar.edu
MAIL_PORT=25
MAIL_USE_TLS=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_FROM=sam-admin@ucar.edu

#-------------------------------------------------
# Flask Application Security
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
FLASK_SECRET_KEY=your_generated_64_character_hex_string_here

#-------------------------------------------------
# Authentication for local development
#
# Default (recommended): AUTH_PROVIDER=stub plus the click-login page at
# /auth/login. Pick any of the DEV_QUICK_LOGIN_USERS buttons (benkirk
# ADMIN, mtrahan CSG, sureshm WNA_SCOPED_ADMIN, …) to land in different
# permission tiers — useful for exercising RBAC paths.
#
# Optional shortcut: set DISABLE_AUTH=1 plus DEV_AUTO_LOGIN_USER=<user>
# to auto-bind every request to a single user, skipping the login page
# entirely. Convenient when you're not testing auth/RBAC, but it hides
# permission boundaries — leave it off if you want the login page back.
# DISABLE_AUTH=1
# DEV_AUTO_LOGIN_USER=benkirk

#-------------------------------------------------
# OIDC Authentication (when AUTH_PROVIDER=oidc)
# Real OIDC is used in deployed environments only:
#   - Fargate staging:   https://sam-staging.csgsam.ucar.edu (env from AWS SSM)
#   - CIRRUS k8s:        https://samuel.k8s.ucar.edu        (env from OpenBao via External Secrets)
#
# Local OIDC against a real IdP (rare, only for protocol-level debugging):
#   1. Use a SEPARATE dev Entra app registration (NOT the staging/prod one) --
#      ask UCAR IT for a dev app with redirect URI http://localhost:5050/auth/oidc/callback.
#      Microsoft Entra allows http://localhost as a special exception for confidential apps.
#   2. Uncomment and fill the values below.
#   3. compose.yaml does NOT pass these envs through to the webdev container by default.
#      Add explicit env entries to compose.yaml's webdev service or `docker compose run -e`.
#   4. Use FLASK_CONFIG=development so SESSION_COOKIE_SECURE=False (HTTP loopback works).
#
# AUTH_PROVIDER=oidc
# OIDC_CLIENT_ID=your-DEV-entra-client-id
# OIDC_CLIENT_SECRET=your-DEV-entra-client-secret
# OIDC_ISSUER=https://login.microsoftonline.com/{tenant-id}/v2.0
# OIDC_REDIRECT_URI=http://localhost:5050/auth/oidc/callback
# OIDC_SCOPES=openid email profile
# OIDC_USERNAME_CLAIM=preferred_username
# FLASK_CONFIG=development

#-------------------------------------------------
# hpc-usage-queries plugin (per-job rows in the webapp)
#
# The plugin lives in a separate package (`pip install -e
# '<path>/hpc-usage-queries[postgres]'`) and talks to its OWN database
# — a per-machine PostgreSQL DB (derecho_jobs, casper_jobs, ...) in
# prod, or per-machine SQLite files in dev. The plugin reads its own
# config (JOB_HISTORY_DB_BACKEND, JOB_HISTORY_PG_*, etc.) at engine-
# creation time; see the plugin's own .env.example.
#
# The values below are SAM-side tuning knobs only — they control how
# the webapp pools connections to that plugin DB and which machines are
# pre-warmed at startup.
#
# Empty JOB_HISTORY_MACHINES disables the integration entirely (useful
# in dev when the plugin isn't installed; tests do this automatically).
# JOB_HISTORY_MACHINES=derecho,casper
# JOB_HISTORY_POOL_SIZE=5
# JOB_HISTORY_POOL_MAX_OVERFLOW=10
# JOB_HISTORY_POOL_RECYCLE=3600

#-------------------------------------------------
# fs-scans plugin (filesystem-scan analytics in the webapp)
#
# Ships in the SAME `hpc-usage-queries[postgres]` wheel as the per-job
# plugin above; the importable package is `fs_scans`. It talks to its
# OWN database — a CNPG/PostgreSQL backend (one DB per filesystem, one
# schema per collection) in prod, or per-collection SQLite files in dev.
# The plugin reads its own connection config from the FS_SCAN_* vars
# below at engine-creation time; see the plugin's own .env.example.
#
# FS_SCANS_ENABLED is the SAM-side master switch (default on). Set it to
# 0 to skip plugin load entirely (useful in dev when the backend isn't
# reachable; tests do this automatically). Collection schemas are
# discovered at startup, so there's no machine/collection list to set.
#
# Unlike job_history, FS_SCAN_PG_HOST is a directly-routable CNPG cluster
# host (e.g. csg-postgres.k8s.ucar.edu) — NOT host.docker.internal — so
# it flows through to the container from here via env_file unchanged.
# FS_SCANS_ENABLED=1
# FS_SCAN_DB_BACKEND=postgres
# FS_SCAN_PG_HOST=csg-postgres.k8s.ucar.edu
# FS_SCAN_PG_PORT=5432
# FS_SCAN_PG_USER=postgres
# FS_SCAN_PG_PASSWORD=
# FS_SCAN_PG_REQUIRE_SSL=false
# FS_SCAN_PG_DB=campaign

#-------------------------------------------------
# MCP Server Configuration
# GitHub MCP Server - requires Personal Access Token with "repo" scope
#   Create token at: https://github.com/settings/tokens
#   Required scopes: repo
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token_here

# AWS MCP Server - AWS credentials (optional, can use AWS CLI default profile)
#   Can also use AWS CLI default profile instead of setting here
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_SESSION_TOKEN=your_aws_session_token_if_needed

# Local Variables:
# mode: sh
# End:
