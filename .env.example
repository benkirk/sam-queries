#-------------------------------------------------
# local container instance
#   "local SAM" is used especially for testing and
#   should always have read/write access
LOCAL_SAM_DB_USERNAME=root
LOCAL_SAM_DB_SERVER=127.0.0.1
LOCAL_SAM_DB_PASSWORD=root

#-------------------------------------------------
# Production SAM instance (read-only)
#   Used for accessing production data
#   Contact CISL staff for credentials
PROD_SAM_DB_USERNAME=your_prod_username
PROD_SAM_DB_SERVER=sam-sql.ucar.edu
PROD_SAM_DB_PASSWORD='your_prod_password'

#-------------------------------------------------
# Staging SAM instance (AWS RDS, requires UCAR VPN)
#   Get credentials: ./scripts/infra/db-creds-staging.sh
#   Switch with: ./scripts/setup/switch_to_staging_db.sh
# STAGING_SAM_DB_USERNAME=<from db-creds-staging.sh>
# STAGING_SAM_DB_SERVER=<from db-creds-staging.sh>
# STAGING_SAM_DB_PASSWORD=<from db-creds-staging.sh>

#-------------------------------------------------
# "proper SAM" is the SAM instance used to feed
#   our dashboards etc... It may be read-only
#   depending on credentials.
#
# To use LOCAL database (default):
SAM_DB_USERNAME=${LOCAL_SAM_DB_USERNAME}
SAM_DB_SERVER=${LOCAL_SAM_DB_SERVER}
SAM_DB_PASSWORD=${LOCAL_SAM_DB_PASSWORD}
SAM_DB_REQUIRE_SSL=false

# To use STAGING database instead, uncomment these and comment out local settings above:
#SAM_DB_USERNAME=${STAGING_SAM_DB_USERNAME}
#SAM_DB_SERVER=${STAGING_SAM_DB_SERVER}
#SAM_DB_PASSWORD=${STAGING_SAM_DB_PASSWORD}
#SAM_DB_REQUIRE_SSL=false

# To use PRODUCTION database instead, uncomment these and comment out local settings above:
#SAM_DB_USERNAME=${PROD_SAM_DB_USERNAME}
#SAM_DB_SERVER=${PROD_SAM_DB_SERVER}
#SAM_DB_PASSWORD=${PROD_SAM_DB_PASSWORD}
#SAM_DB_REQUIRE_SSL=true

#-------------------------------------------------
# system_status database - used to populate
# the System Status Dashboard
# STATUS_DB_DRIVER: "mysql" (default), "postgresql", or "postgres"
STATUS_DB_DRIVER=mysql
STATUS_DB_USERNAME=root
STATUS_DB_PASSWORD=root
STATUS_DB_SERVER=127.0.0.1

#-------------------------------------------------
# Where our data collectors post their results
# STATUS_API_USER and STATUS_API_KEY are API key credentials,
# NOT user login credentials.  Generate a new key pair with:
#   python scripts/gen_api_key.py --username collector
# Then add the printed hash to API_KEYS in src/webapp/config.py.
STATUS_API_URL="http://localhost:5050"
STATUS_API_USER="collector"
STATUS_API_KEY="YOUR_GENERATED_API_KEY_HERE"

#-------------------------------------------------
# JupyterHub Live Statistics API
# Used for real-time JupyterHub stats endpoints
JUPYTERHUB_API_URL=https://jupyterhub.hpc.ucar.edu
JUPYTERHUB_INSTANCE=stable
JUPYTERHUB_API_TOKEN=
JUPYTERHUB_CACHE_TTL=300

#-------------------------------------------------
# Email Configuration
MAIL_SERVER=ndir.ucar.edu
MAIL_PORT=25
MAIL_USE_TLS=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_FROM=sam-admin@ucar.edu

#-------------------------------------------------
# Flask Application Security
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
FLASK_SECRET_KEY=your_generated_64_character_hex_string_here

#-------------------------------------------------
# MCP Server Configuration
# GitHub MCP Server - requires Personal Access Token with "repo" scope
#   Create token at: https://github.com/settings/tokens
#   Required scopes: repo
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token_here

# AWS MCP Server - AWS credentials (optional, can use AWS CLI default profile)
#   Can also use AWS CLI default profile instead of setting here
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_SESSION_TOKEN=your_aws_session_token_if_needed

# Local Variables:
# mode: sh
# End:
